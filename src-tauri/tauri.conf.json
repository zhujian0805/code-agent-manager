{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Code Agent Manager",
  "version": "0.1.0",
  "identifier": "com.chat2anyllm.code-agent-manager",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 5173 --strictPort",
    "beforeBuildCommand": "npm run build && go build -o ../src-tauri/binaries/cam-sidecar-x86_64-pc-windows-msvc.exe ../cmd/cam-sidecar",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Code Agent Manager",
        "width": 1600,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/cam-sidecar"],
    "resources": []
  }
}
